{
  "name": "@materiabill/api",
  "private": true,
  "type": "module",
  "main": "./src/main.ts",
  "types": "./src/main.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config ../../vitest.config.ts --dir test",
    "dev": "node --env-file-if-exists=../../.env --watch --import tsx src/main.ts"
  },
  "dependencies": {
    "@materiabill/config": "workspace:*",
