{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "workspaces": {
    "apps/admin": {
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/api": {
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "apps/worker": {
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "packages/*": {
      "project": ["src/**/*.ts"]
    }
  }
}
