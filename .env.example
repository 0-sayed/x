# Runtime mode shared by API, worker, and admin documentation.
NODE_ENV=development

# API listen port for the NestJS bootstrap shell.
API_PORT=3000

# Vite admin shell dev server port.
ADMIN_PORT=4173

# Root log level fallback for bootstrap services.
LOG_LEVEL=info

# API-specific log level override.
API_LOG_LEVEL=info

# Worker-specific log level override.
WORKER_LOG_LEVEL=info

# Fake bootstrap version string used in local smoke output.
APP_VERSION=0.0.0-bootstrap

# Session OAuth mode for T004; production uses the main OAuth client tuple.
INFRAMODERN_OAUTH_MODE=production

# Session cookie name for T004.
SESSION_COOKIE_NAME=materiabill.sid

# Local HTTP uses false. Set true only when the API is served over HTTPS.
SESSION_COOKIE_SECURE=false

# OAuth state cookie name for T004.
OAUTH_STATE_COOKIE_NAME=materiabill.oauth_state

# Session TTL in seconds for T004.
SESSION_TTL_SECONDS=28800

# OAuth state TTL in seconds for T004.
OAUTH_STATE_TTL_SECONDS=600

# Inframodern API base URL for T004.
INFRAMODERN_URL=http://inframodern.local

# Inframodern frontend URL for T004.
INFRAMODERN_FRONTEND_URL=http://localhost:5174

# Admin shell URL for T004.
ADMIN_URL=http://localhost:4173

# LOCAL ONLY PLACEHOLDER: 32-byte base64 session encryption key for T004. Do not reuse outside local bootstrap.
SESSION_ENCRYPTION_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=

# LOCAL ONLY PLACEHOLDER: session secret for T004. Do not reuse outside local bootstrap.
SESSION_SECRET=local-only-placeholder-session-secret

# Production OAuth client ID for T004.
INFRAMODERN_OAUTH_CLIENT_ID=local-only-placeholder-client-id

# Production OAuth client secret for T004.
INFRAMODERN_OAUTH_CLIENT_SECRET=local-only-placeholder-client-secret

# Production OAuth callback URL for T004.
INFRAMODERN_OAUTH_CALLBACK_URL=http://127.0.0.1:3000/auth/callback

# Sandbox OAuth client ID for T004.
INFRAMODERN_SANDBOX_OAUTH_CLIENT_ID=local-only-placeholder-sandbox-client-id

# Sandbox OAuth client secret for T004.
INFRAMODERN_SANDBOX_OAUTH_CLIENT_SECRET=local-only-placeholder-sandbox-client-secret

# Sandbox OAuth callback URL for T004.
INFRAMODERN_SANDBOX_OAUTH_CALLBACK_URL=http://127.0.0.1:3000/auth/callback

# Local PostgreSQL database name for bootstrap-only wiring.
POSTGRES_DB=materiabill

# Local PostgreSQL username placeholder for bootstrap-only wiring.
POSTGRES_USER=local_user

# Local PostgreSQL password placeholder for bootstrap-only wiring.
POSTGRES_PASSWORD=changeme-local-only

# Host port mapped to the PostgreSQL container.
POSTGRES_PORT=55432

# Local RabbitMQ username placeholder for bootstrap-only wiring.
RABBITMQ_DEFAULT_USER=local_user

# Local RabbitMQ password placeholder for bootstrap-only wiring.
RABBITMQ_DEFAULT_PASS=changeme-local-only

# Host port mapped to the RabbitMQ AMQP listener.
RABBITMQ_PORT=55672

# Host port mapped to the RabbitMQ management UI.
RABBITMQ_MANAGEMENT_PORT=55673

# Optional PostgreSQL URL for later DB tasks; bootstrap code does not consume it.
DATABASE_URL=postgresql://local_user:changeme-local-only@127.0.0.1:55432/materiabill

# Local RabbitMQ URL used by worker consumers and sync admin publishers.
RABBITMQ_URL=amqp://local_user:changeme-local-only@127.0.0.1:55672

# Inframodern RabbitMQ namespace used by sync queues and exchanges.
RABBITMQ_ENVIRONMENT=testing

# Application code used inside queue names.
RABBITMQ_APP_CODE=materiabill

# Required to use sync admin retry and pull endpoints.
SYNC_ADMIN_TOKEN=

# Optional direct database URL for the sync pull contingency.
INFRAMODERN_DB_URL=

# Admin shell pointer to the local bootstrap API.
VITE_API_BASE_URL=http://127.0.0.1:${API_PORT}
